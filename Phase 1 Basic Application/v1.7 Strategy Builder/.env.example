# ══════════════════════════════════════════════════════════════
# MTF Tester — Environment Variables
# Copy this file to .env and fill in the values
# ══════════════════════════════════════════════════════════════

# Server
HOST=127.0.0.1
PORT=8000
DEBUG=false

# Security — REQUIRED for production
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=

# Session
SESSION_EXPIRY_SECONDS=28800

# Trading Safety
MAX_LOT_SIZE=10.0
MAX_OPEN_POSITIONS=20
DEFAULT_RISK_THRESHOLD_PCT=5.0

# Rate Limiting
ORDER_RATE_LIMIT=10
AUTH_RATE_LIMIT=5

# LLM (Phase 2 — not used yet)
LLM_API_KEY=
LLM_MODEL=claude-opus-4-6-20251101
LLM_MAX_TOKENS=4000
